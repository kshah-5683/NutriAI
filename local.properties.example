# Copy this file to local.properties and fill in your API keys.
# DO NOT commit local.properties to version control!

# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration (get from https://supabase.com/dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# USDA FoodData Central API Key — Phase 5.5 (free, no rate-limit for reasonable use)
# Sign up at: https://fdc.nal.usda.gov/api-key-signup.html
# If left blank, FDC lookups are skipped and the app falls back to IFCT 2017 offline data.
USDA_FDC_API_KEY=your_usda_fdc_api_key_here
