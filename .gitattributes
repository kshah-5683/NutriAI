# Set default behavior to automatically normalize line endings
* text=auto

# Enforce LF line endings for source code, markdown, and configuration files
*.kt text eol=lf
*.java text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.gitignore text eol=lf
.gitattributes text eol=lf

# Force CRLF line endings for Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
